# --- Static deployment mode -------------------------------------------------
# true にすると GitHub Actions で事前生成した public/api/*.json を直接読む。
# Vercel にデプロイするときは Vercel の Project Settings → Environment
# Variables で NEXT_PUBLIC_STATIC_MODE=true を設定する。
NEXT_PUBLIC_STATIC_MODE=false

# 別ドメイン (例: GitHub Pages) に JSON を置く場合のベース URL。
# 同じ Vercel Project の public/api/ を使う場合は空のままで OK。
NEXT_PUBLIC_STATIC_BASE=
